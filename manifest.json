{
  "manifest_version": 3,
  "name": "YT Translate",
  "version": "1.1.0",
  "description": "YouTube 沉浸式双语翻译 — 字幕、评论、标题、简介实时翻译",
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "https://api.deepseek.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "all_frames": true,
      "js": [
        "lib/utils.js",
        "lib/cache.js",
        "lib/translator.js",
        "content/page/selectors.js",
        "content/page/injector.js",
        "content/page/observer.js",
        "content/subtitle/extractor.js",
        "content/subtitle/overlay.js",
        "content/main.js"
      ],
      "css": ["content/style.css", "content/subtitle/overlay.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/subtitle/fetcher.js"],
      "matches": ["*://*.youtube.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "YT Translate"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
