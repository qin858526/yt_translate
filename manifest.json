
{
  "manifest_version": 3,
  "name": "YT Translate",
  "version": "1.0.0",
  "description": "YouTube \u6c89\u6d78\u5f0f\u53cc\u8bed\u7ffb\u8bd1 \u2014 \u5b57\u5e55\u3001\u8bc4\u8bba\u3001\u6807\u9898\u3001\u7b80\u4ecb\u5b9e\u65f6\u7ffb\u8bd1",
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "https://api.deepseek.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
    "content_scripts": [
        {
            "matches": ["*://*.youtube.com/*"],
            "js": [
                "lib/utils.js",
                "lib/cache.js",
                "lib/translator.js",
                "content/page/selectors.js",
                "content/page/injector.js",
                "content/page/observer.js",
                "content/subtitle/extractor.js",
                "content/subtitle/overlay.js",
                "content/main.js"
            ],
            "css": ["content/style.css", "content/subtitle/overlay.css"],
            "run_at": "document_start"
        }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "YT Translate"
  },
    "icons": {
        "16": "icons/icon.svg",
        "48": "icons/icon.svg",
        "128": "icons/icon.svg"
    }
}
